{
  "expo": {
    "name": "ServeSaathi",
    "slug": "ServeSaathi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#123214"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.ServeSaathi"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#123214",
        "backgroundImage": "./assets/adaptive-icon-bg.png",
        "foregroundImage": "./assets/adaptive-icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.ServeSaathi"
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#123214"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "ServeSaathi needs access to your photos so you can set a profile picture."
        }
      ]
    ]
  }
}
